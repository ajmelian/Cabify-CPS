{
  "name": "aythami/cabify",
  "description": "Cabify car pooling service in native PHP 8.4 with Hexagonal Architecture",
  "type": "project",
  "license": "proprietary",
  "authors": [
    {
      "name": "Aythami Melián Perdomo",
      "email": "ajmelper@gmail.com"
    }
  ],
  "require": {
    "php": "^8.4",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-simplexml": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "Cabify\\": "src/",
      "Cabify\\Application\\": "Application/",
      "Cabify\\Infrastructure\\": "Infrastructure/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Cabify\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit --configuration phpunit.xml",
    "lint": "find src Application Infrastructure tests public scripts -type f -name '*.php' -print0 | xargs -0 -n1 php -l",
    "coverage": "mkdir -p build/coverage && XDEBUG_MODE=coverage vendor/bin/phpunit --configuration phpunit.xml --coverage-clover build/coverage/clover.xml --coverage-text",
    "coverage:check": "php scripts/check_coverage.php build/coverage/clover.xml 90",
    "migrate": "php scripts/migrate.php",
    "smoke": "bash scripts/smoke.sh",
    "benchmark": "php scripts/benchmark_assignments.php"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
