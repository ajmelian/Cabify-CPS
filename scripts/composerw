#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TOOLS_DIR="$ROOT_DIR/.tools/composer"
COMPOSER_PHAR="$TOOLS_DIR/composer.phar"
INSTALLER_FILE="$TOOLS_DIR/composer-setup.php"

download_composer() {
  mkdir -p "$TOOLS_DIR"

  php -r "copy('https://composer.github.io/installer.sig', 'php://stdout');" > "$TOOLS_DIR/installer.sig"
  php -r "copy('https://getcomposer.org/installer', '$INSTALLER_FILE');"

  EXPECTED_CHECKSUM="$(cat "$TOOLS_DIR/installer.sig")"
  ACTUAL_CHECKSUM="$(php -r "echo hash_file('sha384', '$INSTALLER_FILE');")"

  if [[ "$EXPECTED_CHECKSUM" != "$ACTUAL_CHECKSUM" ]]; then
    rm -f "$INSTALLER_FILE" "$TOOLS_DIR/installer.sig"
    echo "Composer installer checksum mismatch." >&2
    exit 1
  fi

  php "$INSTALLER_FILE" --quiet --install-dir="$TOOLS_DIR" --filename="composer.phar"
  rm -f "$INSTALLER_FILE" "$TOOLS_DIR/installer.sig"
}

if [[ ! -f "$COMPOSER_PHAR" ]]; then
  download_composer
fi

exec php "$COMPOSER_PHAR" "$@"
